{
  "name": "@meetquinn/anima",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "description": "An AI agent team that works alongside your human team in Slack.",
  "homepage": "https://github.com/MeetQuinn/anima#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MeetQuinn/anima.git"
  },
  "bugs": {
    "url": "https://github.com/MeetQuinn/anima/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.0.0",
  "type": "module",
  "bin": {
    "anima": "bin/anima",
    "animactl": "bin/animactl"
  },
  "files": [
    "CLAUDE.md",
    ".env.example",
    "README.md",
    "agent.config.example.json",
    "bin/",
    "config.example.json",
    "dist/server/",
    "dist/shared/",
    "dist/web/",
    "docs/deployment.md",
    "docs/guide/quickstart.md",
    "docs/runtime-providers.md",
    "docs/service-runbook.md",
    "templates/",
    "examples/"
  ],
  "scripts": {
    "build": "rm -rf packages/animactl/dist && pnpm --dir server build && pnpm build:ui && node scripts/prepare-animactl-package.mjs",
    "build:server": "pnpm --dir server build",
    "docs:prepare": "node scripts/prepare-docs-public.mjs",
    "docs:build": "pnpm docs:prepare && vitepress build docs",
    "docs:dev": "pnpm docs:prepare && vitepress dev docs --host 127.0.0.1 --port 14175",
    "docs:preview": "pnpm docs:prepare && vitepress preview docs --host 127.0.0.1 --port 14175",
    "prepare": "husky",
    "lint": "pnpm --dir web lint",
    "type-check": "pnpm --dir server type-check && pnpm --dir web type-check",
    "build:ui": "cd web && pnpm build",
    "pack:check": "pnpm build && npm pack --dry-run --ignore-scripts",
    "pack:tarball": "rm -f meetquinn-anima-*.tgz anima-*.tgz && npm pack",
    "prepack": "pnpm build",
    "services:restart": "pnpm build && node dist/server/cli/animactl.js services restart",
    "services:start": "node dist/server/cli/animactl.js services start",
    "services:status": "node dist/server/cli/animactl.js services status",
    "services:stop": "node dist/server/cli/animactl.js services stop",
    "dev:services:restart": "pnpm build && node scripts/ensure-dev-anima-home.mjs && ANIMA_HOME=./.anima-dev node dist/server/cli/animactl.js services restart",
    "dev:services:start": "node scripts/ensure-dev-anima-home.mjs && ANIMA_HOME=./.anima-dev node dist/server/cli/animactl.js services start",
    "dev:services:status": "node scripts/ensure-dev-anima-home.mjs && ANIMA_HOME=./.anima-dev node dist/server/cli/animactl.js services status",
    "dev:services:stop": "node scripts/ensure-dev-anima-home.mjs && ANIMA_HOME=./.anima-dev node dist/server/cli/animactl.js services stop",
    "test": "pnpm test:fast",
    "test:fast": "pnpm --dir server test:fast",
    "test:fast:dist": "pnpm --dir server test:fast:dist",
    "test:unit": "pnpm --dir server test:unit",
    "test:api": "pnpm --dir server test:api",
    "test:runtime": "pnpm --dir server test:runtime",
    "test:all": "pnpm build && node scripts/run-tests.mjs all",
    "typecheck": "pnpm --dir server type-check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.71.0",
    "@larksuiteoapi/node-sdk": "^1.66.1",
    "@slack/bolt": "^4.7.2",
    "@slack/web-api": "^7.15.2",
    "commander": "^14.0.3",
    "eciesjs": "0.4.18",
    "fastify": "^5.8.5",
    "ignore": "^7.0.5",
    "luxon": "^3.7.2",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "web/**/*.{ts,tsx}": [
      "pnpm --dir web exec eslint --fix"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  }
}
